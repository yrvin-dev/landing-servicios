---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.jsx'
import Testimonios from '../components/Testimonios.jsx'
import Contacto from '../components/Contacto.jsx'

const [resHero, resServicios, resTestimonios, resClientes] = await Promise.all([
  fetch('http://localhost:1337/api/hero'),
  fetch('http://localhost:1337/api/servicios'),
  fetch('http://localhost:1337/api/testimonios'),
  fetch('http://localhost:1337/api/clientes')
])

const { data: hero } = await resHero.json()
const { data: servicios } = await resServicios.json()
const { data: testimonios } = await resTestimonios.json()
const { data: clientes } = await resClientes.json()
---

<Layout title="Agencia Web — Desarrollo a medida">
  <main>

    <Navbar client:load />

    <section class="bg-gray-900 text-white py-24 px-6 text-center">
      <h1 class="text-5xl font-bold mb-6">{hero.titulo}</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-8">{hero.subtitulo}</p>
      <a href={hero.url_boton} class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition">
        {hero.texto_boton}
      </a>
    </section>

    <section id="servicios" class="py-20 px-6 max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Nuestros Servicios</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {servicios.map((servicio) => (
          <div class="bg-white border border-gray-200 rounded-xl p-8 shadow-sm hover:shadow-md transition">
            <h3 class="text-xl font-semibold mb-3">{servicio.titulo}</h3>
            <p class="text-gray-600">{servicio.descripcion[0]?.children[0]?.text}</p>
          </div>
        ))}
      </div>
    </section>

    <Testimonios testimonios={testimonios} client:load />

    <section class="py-16 px-6 max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-center text-gray-400 mb-10">Empresas que confían en nosotros</h2>
      <div class="flex flex-wrap justify-center gap-10">
        {clientes.map((cliente) => (
          <a href={cliente.url} target="_blank" class="text-gray-500 font-semibold text-lg hover:text-blue-600 transition">
            {cliente.nombre}
          </a>
        ))}
      </div>
    </section>

    <Contacto client:load />

    <footer class="bg-gray-900 text-gray-400 py-10 px-6 text-center">
      <p class="text-white font-bold text-xl mb-2">AgenciaWeb</p>
      <p class="mb-4">Desarrollamos tu presencia digital con tecnología moderna.</p>
      <p class="text-sm">© 2026 AgenciaWeb. Todos los derechos reservados.</p>
    </footer>

  </main>
</Layout>